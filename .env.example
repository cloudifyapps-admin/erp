# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_db

# ERP database URLs (used by backend, celery-worker, celery-beat)
DATABASE_URL=postgresql+asyncpg://erp_user:erp_password@postgres:5432/erp_db
DATABASE_URL_SYNC=postgresql://erp_user:erp_password@postgres:5432/erp_db

# Keycloak database (separate DB on same PostgreSQL instance)
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_db
KC_DB_USERNAME=erp_user
KC_DB_PASSWORD=erp_password

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO ────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000

# ─── Backend ─────────────────────────────────────────
SECRET_KEY=cloudifyapps-erp-secret-change-in-production
CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]
DEBUG=true

# ─── Email (MailHog) ─────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
EMAIL_FROM_ADDRESS=noreply@cloudifyapps.com
EMAIL_FROM_NAME=Cloudifyapps ERP

# ─── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=Cloudifyapps ERP
FRONTEND_URL=http://localhost:3000

# ─── Keycloak Admin ──────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── pgAdmin ─────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@cloudifyapps.com
PGADMIN_DEFAULT_PASSWORD=admin123
